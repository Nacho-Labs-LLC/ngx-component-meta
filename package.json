{
  "name": "ngx-component-meta",
  "version": "0.1.0",
  "description": "Lightweight Angular component metadata extractor — inputs, outputs, models, methods, types from source",
  "license": "MIT",
  "author": "Nate Richardson",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nacho-Labs-LLC/ngx-component-meta.git"
  },
  "homepage": "https://github.com/Nacho-Labs-LLC/ngx-component-meta#readme",
  "bugs": {
    "url": "https://github.com/Nacho-Labs-LLC/ngx-component-meta/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storybook": {
      "types": "./dist/storybook/index.d.ts",
      "import": "./dist/storybook/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ngx-component-meta": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "angular",
    "component",
    "metadata",
    "docgen",
    "documentation",
    "storybook",
    "inputs",
    "outputs",
    "signals",
    "ngx"
  ]
}
