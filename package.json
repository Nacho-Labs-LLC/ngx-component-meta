{
  "name": "@nacho-labs/ngx-component-meta",
  "version": "0.1.0",
  "description": "Lightweight Angular component metadata extractor — inputs, outputs, models, methods, types from source",
  "license": "MIT",
  "author": "Nate Richardson",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nacho-Labs-LLC/ngx-component-meta.git"
  },
  "homepage": "https://github.com/Nacho-Labs-LLC/ngx-component-meta#readme",
  "bugs": {
    "url": "https://github.com/Nacho-Labs-LLC/ngx-component-meta/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storybook": {
      "types": "./dist/storybook/index.d.ts",
      "import": "./dist/storybook/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ngx-component-meta": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "build:action": "node scripts/build-action.mjs"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@typescript/typescript6": "^6.0.2"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^9.1.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "angular",
    "component",
    "metadata",
    "docgen",
    "documentation",
    "storybook",
    "inputs",
    "outputs",
    "signals",
    "ngx"
  ]
}
